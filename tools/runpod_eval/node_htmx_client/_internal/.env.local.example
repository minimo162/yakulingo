# Local overrides (this file itself can be committed as template).
# Copy to ".env.local" and set your pod-specific values there.

# RunPod OpenAI-compatible endpoint (include /v1)
RUNPOD_BASE_URL=https://<pod-id>-11434.proxy.runpod.net/v1

# Keep marker unless you intentionally store key in this file.
RUNPOD_API_KEY=__USE_DPAPI__

