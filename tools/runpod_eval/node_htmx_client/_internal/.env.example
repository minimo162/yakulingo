# RunPod OpenAI-compatible endpoint (include /v1)
RUNPOD_BASE_URL=https://<pod-id>-11434.proxy.runpod.net/v1

# Keep marker. Token is loaded from local DPAPI secure store.
RUNPOD_API_KEY=__USE_DPAPI__

# Default model shown in the UI.
DEFAULT_MODEL=gpt-oss-swallow-120b-iq4xs

# Local app bind.
APP_PORT=3030
APP_BIND=127.0.0.1

# Upstream timeout for chat requests.
RUNPOD_REQUEST_TIMEOUT_MS=90000
