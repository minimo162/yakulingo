# RunPod OpenAI-compatible endpoint (include /v1).
# Keep placeholder here. Put actual pod URL in untracked ".env.local".
RUNPOD_BASE_URL=https://<pod-id>-11434.proxy.runpod.net/v1
# Optional additional routes (comma-separated). Used for automatic failover.
# Example:
# RUNPOD_BASE_URL_CANDIDATES=https://<pod-a>-11434.proxy.runpod.net/v1,https://<pod-b>-11434.proxy.runpod.net/v1
RUNPOD_BASE_URL_CANDIDATES=
# Route probe before send (GET /models).
RUNPOD_ROUTE_PROBE_ENABLED=1
RUNPOD_ROUTE_PROBE_TIMEOUT_MS=6000
# Cooldown seconds for failing routes before retrying them.
RUNPOD_ROUTE_COOLDOWN_SEC=90

# Keep marker. Token is loaded from local DPAPI secure store.
# You can also set values in ".env.local" (untracked).
RUNPOD_API_KEY=__USE_DPAPI__

# Default model shown in the UI.
DEFAULT_MODEL=gpt-oss-swallow-120b-iq4xs
# Codex exec model ID (default: same as DEFAULT_MODEL for LM Studio on RunPod).
CODEX_EXEC_MODEL=gpt-oss-swallow-120b-iq4xs
# Codex config provider id for LM Studio over RunPod proxy.
CODEX_LMSTUDIO_PROVIDER_ID=lmstudio-runpod

# Agent backend is fixed to codex_cli by the server.
# This value is kept for compatibility only.
AGENT_BACKEND=codex_cli

# Codex runtime policy.
# 1 = always use bundled codex under .runtime/codex (recommended/default)
# 0 = allow PATH fallback (advanced/troubleshooting only)
CODEX_REQUIRE_BUNDLED=1
# Package installed by prepare-node-runtime.ps1 into bundled runtime.
CODEX_BUNDLED_PACKAGE=@openai/codex@latest
# Optional explicit codex path (used only when CODEX_REQUIRE_BUNDLED=0).
CODEX_BIN=

# Optional codex home path (stores config.toml and sessions).
# Empty -> %LOCALAPPDATA%\YakuLingoRunpodHtmx\codex-home
CODEX_HOME=

# codex exec timeout (seconds)
CODEX_EXEC_TIMEOUT_SEC=900
# codex route mode: native | resilient | background_poll
# Default: disable native stream and use responses background/poll first.
CODEX_EXEC_ROUTE_MODE=background_poll
# Legacy switch (kept for compatibility). 0 recommended when route mode is background_poll.
CODEX_NATIVE_MODE=0

# codex exec flags
CODEX_FULL_AUTO=1
CODEX_SKIP_GIT_REPO_CHECK=1
CODEX_DANGEROUS_BYPASS=0
# Extra args appended to codex exec command line (advanced)
CODEX_EXTRA_ARGS=

# codex exec send conditions (RunPod tuning)
# Provider retry/stream behavior
CODEX_PROVIDER_REQUEST_MAX_RETRIES=1
CODEX_PROVIDER_STREAM_MAX_RETRIES=2
CODEX_PROVIDER_STREAM_IDLE_TIMEOUT_MS=45000
# Model behavior
CODEX_MODEL_CONTEXT_WINDOW=32768
CODEX_MINIMAL_MODEL_INSTRUCTIONS=0
# Optional custom path for minimal instructions file (absolute or repo-relative).
# If empty, auto-generated at CODEX_HOME/model_instructions.min.md
CODEX_MINIMAL_MODEL_INSTRUCTIONS_FILE=
CODEX_MODEL_REASONING_EFFORT=minimal
CODEX_MODEL_REASONING_SUMMARY=auto
CODEX_MODEL_VERBOSITY=low
# Prompt/project-doc size caps before send
CODEX_PROJECT_DOC_MAX_BYTES=0
CODEX_PROMPT_MAX_CHARS=12000
# Prompt transport compaction (for long instructions).
CODEX_PROMPT_COMPRESSION_ENABLED=0
CODEX_PROMPT_COMPRESSION_TRIGGER_CHARS=9000
CODEX_PROMPT_COMPRESSION_TARGET_CHARS=7600
CODEX_PROMPT_KEEP_HEAD_CHARS=2400
CODEX_PROMPT_KEEP_TAIL_CHARS=3200
CODEX_PROMPT_KEY_LINES_LIMIT=40
# Progress ping while codex exec is waiting for upstream output.
CODEX_EXEC_PROGRESS_PING_INTERVAL_MS=8000
# Outer retry strategy when codex stream breaks before response.completed
CODEX_EXEC_RETRY_MAX_ATTEMPTS=3
CODEX_EXEC_RETRY_BASE_DELAY_MS=800
CODEX_EXEC_RETRY_MAX_DELAY_MS=4000
# Final recovery path (non-stream /responses) after stream retries fail
CODEX_STREAM_RECOVERY_FALLBACK_ENABLED=1
CODEX_STREAM_RECOVERY_TIMEOUT_MS=90000
# Codex web tool policy.
# disabled|cached|live (recommended: live)
CODEX_WEB_SEARCH_MODE=live
# If Codex returns no tool activity for live web queries, fallback to engine tool chain.
CODEX_TOOL_FALLBACK_TO_ENGINE=0
# Force fallback even when Codex did not explicitly mention network restrictions.
CODEX_TOOL_FALLBACK_FORCE_FOR_LIVE_WEB=0
# Use synchronous /responses call by default (RunPod + LM Studio is more stable without background poll).
RUNPOD_RESPONSES_BACKGROUND_ENABLED=0
RUNPOD_RESPONSES_POLL_INTERVAL_MS=1500
RUNPOD_RESPONSES_POLL_TIMEOUT_MS=180000
# Responses API tools for background/poll route (comma separated)
RUNPOD_RESPONSES_TOOLS_ENABLED=1
# Legacy shorthand (e.g. web_search). Keep empty when using JSON tool definitions.
RUNPOD_RESPONSES_TOOL_TYPES=
# Optional explicit function/mcp tool definitions (JSON array)
# RUNPOD_RESPONSES_FUNCTION_TOOLS_JSON=[{"type":"function","name":"read_local_file","description":"Read local text file","parameters":{"type":"object","properties":{"path":{"type":"string"}},"required":["path"]}}]
# RUNPOD_RESPONSES_MCP_TOOLS_JSON=[{"type":"mcp","server_label":"weather","server_url":"http://127.0.0.1:8765/mcp","allowed_tools":["search_weather"]}]
RUNPOD_RESPONSES_FUNCTION_TOOLS_JSON=
RUNPOD_RESPONSES_MCP_TOOLS_JSON=
# none|auto|required
RUNPOD_RESPONSES_TOOL_CHOICE=auto
# inherit|none|auto|required (used when prompt likely needs live web)
RUNPOD_RESPONSES_LIVE_WEB_TOOL_CHOICE=auto
# If enabled, live-web prompts fail when response contains no tool evidence.
RUNPOD_RESPONSES_REQUIRE_TOOL_FOR_LIVE_WEB=1
# If enabled, missing tool evidence becomes a hard error.
# Recommended 0: keep assistant text even when endpoint skips tool execution.
RUNPOD_RESPONSES_HARD_FAIL_ON_MISSING_TOOL=0

# Optional local MCP weather server (for LM Studio Remote MCP).
# NOTE: If your model endpoint is remote (e.g. RunPod), set LOCAL_MCP_WEATHER_PUBLIC_URL
# to a URL reachable from that remote host.
LOCAL_MCP_WEATHER_ENABLED=0
LOCAL_MCP_WEATHER_BIND=127.0.0.1
LOCAL_MCP_WEATHER_PORT=8765
LOCAL_MCP_WEATHER_PUBLIC_URL=
LOCAL_MCP_WEATHER_SERVER_LABEL=weather
LOCAL_MCP_WEATHER_ALLOWED_TOOLS=search_weather
# Optional external Playwright Remote MCP (reachable from model host).
PLAYWRIGHT_REMOTE_MCP_ENABLED=0
PLAYWRIGHT_REMOTE_MCP_SERVER_LABEL=playwright
PLAYWRIGHT_REMOTE_MCP_URL=
PLAYWRIGHT_REMOTE_MCP_AUTO_FROM_RUNPOD=1
PLAYWRIGHT_REMOTE_MCP_ALLOWED_TOOLS=browser_navigate,browser_snapshot
# Optional JSON object for Remote MCP request headers.
# Example: {"Authorization":"Bearer <token>","x-api-key":"<token>"}
PLAYWRIGHT_REMOTE_MCP_HEADERS_JSON=

# Local app bind.
APP_PORT=3030
APP_BIND=127.0.0.1
ENGINE_PORT=3031
ENGINE_BIND=127.0.0.1
# Relative date resolution time zone (today/tomorrow in auto tool chat).
APP_TIME_ZONE=Asia/Tokyo

# Bundled Python runtime provisioning (uv managed standalone).
PYTHON_RUNTIME_SPEC=3.11
# Optional explicit uv target (usually auto-detected):
# x86_64-pc-windows-msvc / aarch64-pc-windows-msvc / i686-pc-windows-msvc
# PYTHON_RUNTIME_UV_TARGET=

# Generation best-practice defaults.
# Recommended: temperature=0.6, top_p=0.95, top_k=20, min_p=0
GENERATION_TEMPERATURE=0.6
GENERATION_TOP_P=0.95
GENERATION_TOP_K=20
GENERATION_MIN_P=0

# Max context length recommendation: 32,768 or less.
# Server trims message history by approximate char budget to stay under this token cap.
GENERATION_MAX_CONTEXT_TOKENS=32768
# Extra margin reserved for protocol/tool overhead.
GENERATION_CONTEXT_RESERVE_TOKENS=512

# Session history/context compaction tuning (Codex-like).
MAX_HISTORY_PAIRS=16
HISTORY_COMPACTION_KEEP_RECENT_PAIRS=4
HISTORY_COMPACTION_SUMMARY_MAX_CHARS=18000
SESSION_AUTO_COMPACT_TOKEN_LIMIT=22000
SESSION_COMPACTION_TARGET_RATIO=0.68
SESSION_COMPACTION_SYSTEM_PROMPT_RESERVE_TOKENS=2400

# Optional override for auto-tool decision temperature.
# If unset, GENERATION_TEMPERATURE is used.
# AUTO_TOOL_TEMPERATURE=0.6

# Upstream timeout for chat requests.
RUNPOD_REQUEST_TIMEOUT_MS=120000
# Optional per-endpoint timeout overrides.
RUNPOD_MODELS_TIMEOUT_MS=30000
RUNPOD_CHAT_TIMEOUT_MS=120000
# Upstream transient retry (applies to /models and /chat/completions).
RUNPOD_HTTP_RETRY_MAX_ATTEMPTS=5
RUNPOD_HTTP_RETRY_DELAY_MS=1200
RUNPOD_HTTP_RETRY_MAX_DELAY_MS=10000
# Pre-chat health check (cached for TTL).
RUNPOD_HEALTHCHECK_ON_CHAT=1
RUNPOD_HEALTHCHECK_TTL_MS=20000
# TLS verification for direct RunPod HTTP calls (route probe / responses fallback).
# 1: verify certificate (default), 0: skip verification (use only in trusted corporate proxy environments).
RUNPOD_TLS_VERIFY=1
# Prefer OS/system certificate store when verifying TLS certs.
RUNPOD_TLS_USE_SYSTEM_STORE=1
# Retry once with verify=False after TLS failure (insecure; last resort only).
RUNPOD_TLS_RETRY_NO_VERIFY=0
# Optional custom CA bundle path for corporate/intercepting proxy root cert.
RUNPOD_CA_BUNDLE=

# RunPod startup connection-test policy.
# strict: fail startup when test fails, soft: warn and continue startup.
RUNPOD_CONNECTION_TEST_MODE=strict
# Retry tuning (soft mode still retries before warning).
RUNPOD_CONNECTION_TEST_MAX_ATTEMPTS=4
RUNPOD_CONNECTION_TEST_RETRY_DELAY_SEC=2
RUNPOD_CONNECTION_TEST_TIMEOUT_SEC=8

# Workspace is fixed to:
# tools/runpod_eval/node_htmx_client/workspace
# Write operations are restricted to this directory tree.

# Max bytes for regular text/binary reads.
MAX_READ_BYTES=262144
# Max bytes for PDF files (text extracted via Python + PyMuPDF).
MAX_PDF_READ_BYTES=20971520
MAX_PDF_READ_PAGES=20
MAX_PDF_READ_CHARS=80000
# Max bytes/chars/items for Office files (.xlsx/.docx/.pptx).
MAX_OFFICE_READ_BYTES=20971520
MAX_OFFICE_READ_CHARS=80000
MAX_OFFICE_READ_ITEMS=4000

# Auto-tool robustness.
AUTO_TOOL_JSON_REPAIR_RETRIES=1
AUTO_TOOL_JSON_REPAIR_MAX_CHARS=8000

# Playwright MCP web search.
PLAYWRIGHT_MCP_ENABLED=1
PLAYWRIGHT_MCP_BROWSER=chromium
PLAYWRIGHT_MCP_HEADLESS=1
PLAYWRIGHT_MCP_TIMEOUT_MS=300000
PLAYWRIGHT_MCP_MAX_RESULTS=5

# Browser client heartbeat + auto stop.
# When all browser clients are gone, server exits after idle timeout.
CLIENT_AUTOSTOP_ENABLED=1
CLIENT_HEARTBEAT_INTERVAL_MS=15000
CLIENT_HEARTBEAT_STALE_MS=45000
CLIENT_AUTOSTOP_IDLE_MS=30000
CLIENT_HEARTBEAT_SWEEP_MS=5000
CLIENT_AUTOSTOP_REQUEST_GRACE_MS=30000

# Stream keepalive while waiting for long model/tool responses.
STREAM_KEEPALIVE_INTERVAL_MS=10000
# Assistant answer incremental rendering over NDJSON stream.
ASSISTANT_STREAM_ENABLED=1
ASSISTANT_STREAM_CHUNK_CHARS=48
ASSISTANT_STREAM_CHUNK_DELAY_MS=12

# Shell command timeout (milliseconds).
LOCAL_SHELL_TIMEOUT_MS=20000

# Allowed shell command prefixes (comma separated, case-insensitive).
# Empty uses server defaults:
# git status, git diff, git log, git show, git branch, git rev-parse,
# rg, pwd, ls, dir, Get-ChildItem, type, cat
LOCAL_SHELL_ALLOWLIST=

# Autonomous loop settings.
AUTONOMOUS_LOOP_MAX_ITERS=3
AUTONOMOUS_MAX_FILES_PER_ITER=4
AUTONOMOUS_MAX_FILE_CONTEXT_CHARS=12000
AUTONOMOUS_MAX_VALIDATION_COMMANDS=4
AUTONOMOUS_MODEL_MAX_TOKENS=4000
