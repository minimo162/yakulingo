# Local overrides (untracked). Copy this file to ".env.local".

RUNPOD_BASE_URL=https://<pod-id>-11434.proxy.runpod.net/v1
RUNPOD_API_KEY=__USE_DPAPI__
# RUNPOD_UPSTREAM_API_KEY=
# RUNPOD_INFERENCE_PROVIDER=ollama

# Optional model/provider overrides
# DEFAULT_MODEL=gpt-oss-swallow-120b-iq4xs
# CODEX_EXEC_MODEL=gpt-oss-swallow-120b-iq4xs
# CODEX_PROVIDER_ID=ollama-runpod
# CODEX_WIRE_API=chat

# Route mode / live-web defaults
# CODEX_EXEC_ROUTE_MODE=resilient
# CODEX_TOOL_FALLBACK_TO_ENGINE=1
# CODEX_TOOL_FALLBACK_FORCE_FOR_LIVE_WEB=1
# LIVE_WEB_TOOL_EXEC_MODE=engine_primary
# LIVE_WEB_REQUIRE_EVIDENCE=1

# Optional RunPod route probing
# RUNPOD_BASE_URL_CANDIDATES=
# RUNPOD_ROUTE_PROBE_ENABLED=1
# RUNPOD_ROUTE_PROBE_TIMEOUT_MS=6000
# RUNPOD_ROUTE_COOLDOWN_SEC=90

# Optional responses settings
# RUNPOD_RESPONSES_BACKGROUND_ENABLED=0
# RUNPOD_RESPONSES_POLL_INTERVAL_MS=1500
# RUNPOD_RESPONSES_POLL_TIMEOUT_MS=180000
# RUNPOD_RESPONSES_TOOL_CHOICE=auto
# RUNPOD_RESPONSES_LIVE_WEB_TOOL_CHOICE=auto
# RUNPOD_RESPONSES_REQUIRE_TOOL_FOR_LIVE_WEB=1
# RUNPOD_RESPONSES_HARD_FAIL_ON_MISSING_TOOL=0

# Optional MCP settings
# PLAYWRIGHT_REMOTE_MCP_ENABLED=1
# PLAYWRIGHT_REMOTE_MCP_URL=
# PLAYWRIGHT_REMOTE_MCP_AUTO_FROM_RUNPOD=1
# PLAYWRIGHT_REMOTE_MCP_SERVER_LABEL=playwright
# PLAYWRIGHT_REMOTE_MCP_ALLOWED_TOOLS=browser_navigate,browser_snapshot,browser_click,browser_type,browser_wait_for
# PLAYWRIGHT_REMOTE_MCP_HEADERS_JSON={"Authorization":"Bearer <token>","x-api-key":"<token>"}

# Optional quality/log settings
# WEATHER_DEFAULT_LOCATION=Hiroshima
# PLAYWRIGHT_MODEL_QUERY_ENABLED=1
# PROGRESS_LOG_MODE=concise
